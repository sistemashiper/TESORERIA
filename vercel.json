{
    "version": 2,
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        },
        {
            "src": "server.ts",
            "use": "@vercel/node",
            "runtime": "nodejs18.x",
            "config": {
                "includeFiles": [
                    "src/**",
                    "package.json",
                    "tsconfig.json"
                ]
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "server.ts"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}